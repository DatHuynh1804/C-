//The program that calculate the roots of a second degree polynomial
#include <iostream>
#include<iomanip>
#include<cmath>
#include<cstdlib>
double Discriminant(double a, double b, double c);
void Coefficients_and_roots(double a, double b, double c, double& x1, double& x2);
int main () {
    double a, b, c, D, x1, x2;
    std::cout<<"Enter a, b, c: ";
    std::cin>> a >> b >> c;
    if (a == 0) {
    std::cerr<<"This is not a second degree polynomial!";
     exit(0);
    }
    D = Discriminant(a, b, c);
    std::cout<<"Discriminant D = "<<D<<std::endl;
    Coefficients_and_roots(a, b, c, x1, x2);
    if (D>0) {
        std::cout<<std::defaultfloat<<std::setprecision(5)<<"The polynomial has two roots: "<<"x1 = "
        <<x1<<" ,x2 = "<<x2;
    }
    else if (D==0) {
        std::cout<<std::defaultfloat<<std::setprecision(5)<<"The polynomial has double roots: "<<"x1 = x2 = "<< x1;
    }
    else {
        std::cout<<"The polynomial has no real roots!";
    }
    return 0;
}
double Discriminant(double a, double b, double c) {
    return b * b - 4 * a * c;
    
}
void Coefficients_and_roots(double a, double b, double c, double& x1, double& x2) {
    double D = Discriminant(a, b, c);
    if (D>=0) {
        D = sqrt(D);
        x1 = (-b - D) / (2 * a);
        x2 = (-b + D) / (2 * a);
     }
    else {
        std::cerr<<"Can't calculate D! (D<0)\n";
    }
    }

